# ============================================================
# Sistema de Alertas Eero -> WhatsApp (Cloud API de Meta)
# Copia como ".env" y completa. NUNCA subas el .env real.
# ============================================================

# --- Eero ---
EERO_ADMIN_TOKEN=pega_aqui_tu_token_admin_verificado
EERO_ORG_ID=self

# --- Polling ---
POLL_MINUTES=10
RENOTIFY_MINUTES=10
# Cuantas alertas por mensaje consolidado (plantilla)
BATCH_SIZE=10

# --- Link Insights ---
INSIGHT_URL_TEMPLATE=https://insight.eero.com/networks/{network_id}

# --- WhatsApp Cloud API (Meta) ---
# Token permanente (System User)
WA_TOKEN=pega_aqui_el_token_permanente
# Phone Number ID (Paso 1. Pruebalo)
WA_PHONE_NUMBER_ID=1234567890
WA_API_VERSION=v21.0
# Plantilla aprobada (1 variable de cuerpo) e idioma
WA_TEMPLATE_NAME=alertas_eero
WA_TEMPLATE_LANG=es
# Numeros destino de las alertas (coma-separados, solo digitos con indicativo)
WA_RECIPIENTS=573024808888
# Palabra secreta que TU inventas para verificar el webhook con Meta
WA_VERIFY_TOKEN=inventa_una_palabra_secreta

# --- Monitoreo unhealthy en tiempo real ---
UNHEALTHY_ENABLED=true

# --- General ---
# DRY_RUN=true imprime en consola sin enviar (modo prueba)
DRY_RUN=true
# Puerto local del webhook (Render inyecta PORT automaticamente)
PORT=10000
